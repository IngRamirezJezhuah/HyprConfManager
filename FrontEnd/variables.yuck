;; -- Variables de Conexion Actual --
(defpoll wifi-current :interval "2s"
  "./bin/wifi_status")

;; -- Lista de redes Disponibles --
(defpoll wifi-networks :interval "15s"
  "./bin/wifi_list")

;; --variables de Estado para el Input --
(defvar selected-ssid "")
(defvar show-pass-input false)
(defvar wifi-password "")
(defvar active-view "wifi")
